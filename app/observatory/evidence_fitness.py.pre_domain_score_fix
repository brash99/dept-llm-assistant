def _source_text(item: Evidence) -> str:
    citation = item.result.citation or {}

    parts = [
        citation.get("title") or "",
        citation.get("relative_path") or "",
        citation.get("source_path") or "",
        item.result.text or "",
    ]

    return " ".join(parts).lower()



EVIDENCE_CLASS_STRENGTH = {
    EvidenceClass.CONSTITUTIONAL: 0.55,
    EvidenceClass.INSTITUTIONAL: 1.00,
    EvidenceClass.PLANNING: 0.65,
    EvidenceClass.HISTORICAL: 0.60,
    EvidenceClass.EXTERNAL_STANDARD: 0.90,
    EvidenceClass.EXTERNAL_COMPARATOR: 0.55,
    EvidenceClass.BACKGROUND: 0.30,
}


def _grade_topic(
    keywords: Tuple[str, ...],
    evidence_items: List[Evidence],
) -> tuple[str, float, Dict[str, object]]:
    """
    Grade one evidence domain using three inspectable signals:

    1. keyword breadth;
    2. number of distinct supporting sources;
    3. strength of the supporting evidence classes.

    This measures evidentiary support, not merely whether a word appears.
    """
    supporting_items = []
    matched_keywords = set()

    for item in evidence_items:
        text = _source_text(item)

        item_matches = {
            keyword
            for keyword in keywords
            if keyword in text
        }

        if not item_matches:
            continue

        supporting_items.append(item)
        matched_keywords.update(item_matches)

    source_count = len(supporting_items)
    keyword_count = len(matched_keywords)

    if not supporting_items:
        return (
            "missing",
            0.0,
            {
                "sources": 0,
                "keywords": 0,
                "best_class_strength": 0.0,
                "mean_class_strength": 0.0,
            },
        )

    strengths = [
        EVIDENCE_CLASS_STRENGTH.get(
            item.evidence_class,
            0.30,
        )
        for item in supporting_items
    ]

    best_strength = max(strengths)
    mean_strength = sum(strengths) / len(strengths)

    # Breadth reaches full credit after three distinct keyword concepts.
    breadth_score = min(
        1.0,
        keyword_count / 3.0,
    )

    # Source corroboration reaches full credit after three distinct sources.
    source_score = min(
        1.0,
        source_count / 3.0,
    )

    class_score = (
        0.60 * best_strength
        + 0.40 * mean_strength
    )

    support_score = (
        0.35 * breadth_score
        + 0.35 * source_score
        + 0.30 * class_score
    )

    # Prevent one passing mention from being graded as adequate.
    if source_count == 1 and keyword_count == 1:
        support_score = min(
            support_score,
            0.34,
        )

    if support_score >= 0.78:
        grade = "strong"
    elif support_score >= 0.52:
        grade = "partial"
    elif support_score > 0:
        grade = "weak"
    else:
        grade = "missing"

    return (
        grade,
        round(support_score, 3),
        {
            "sources": source_count,
            "keywords": keyword_count,
            "best_class_strength": round(
                best_strength,
                3,
            ),
            "mean_class_strength": round(
                mean_strength,
                3,
            ),
        },
    )


