class _LinkExtractor(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self.links: List[str] = []

    def handle_starttag(self, tag, attrs) -> None:
        if tag.casefold() not in {"a", "link"}:
            return

        attributes = dict(attrs)
        href = attributes.get("href")

        if href:
            self.links.append(href)


