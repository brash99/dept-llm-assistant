observers:
- name: institutional_research
  enabled: true
  type: web
  source_organization: CNU Institutional Research
  authority: institutional_primary
  purposes:
  - institutional_research
  - enrollment
  - strategic_planning
  - assessment
  seed_urls:
  - https://my.cnu.edu/institutionalresearch/
  - https://cnu.edu/institutionalresearch/
  allowed_hosts:
  - my.cnu.edu
  - cnu.edu
  allowed_prefixes:
  - https://my.cnu.edu/institutionalresearch/
  - https://cnu.edu/institutionalresearch/
  storage_root: storage/raw_web
  manifest: storage/manifests/cnu_institutional_research.jsonl
  max_depth: 10
  max_pages: 1000
  request_delay_seconds: 0.5
  respect_robots: false
  authorization:
    mode: institutional_approval
    approved_by:
    - Quentin Kidd
    - Carolyn Davis
    scope:
    - https://my.cnu.edu/institutionalresearch/
    - https://cnu.edu/institutionalresearch/
    notes: Authorized for the Institutional Semantic Observatory pilot and strategic-planning
      work.
