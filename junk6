import yaml

from app.acquisition.authority import SourceAuthority


@dataclass(frozen=True)
class ObserverAuthorization:
    """
    Governance provenance for an institutional observer.

    This records why an observer is permitted to operate when its configured
    policy differs from a site's public automated-access policy.
    """

    mode: str
    approved_by: Tuple[str, ...]
    scope: Tuple[str, ...]
    notes: Optional[str] = None

    @classmethod
    def from_dict(
        cls,
        payload: Dict[str, Any],
    ) -> "ObserverAuthorization":
        mode = str(payload.get("mode", "")).strip()
        approved_by = tuple(payload.get("approved_by", []))
        scope = tuple(payload.get("scope", []))
        notes = payload.get("notes")

        if not mode:
            raise ValueError(
                "Observer authorization mode must not be empty."
            )

        if mode == "institutional_approval":
            if not approved_by:
                raise ValueError(
                    "Institutional approval requires at least one approver."
                )

            if not scope:
                raise ValueError(
                    "Institutional approval requires an explicit scope."
                )

        return cls(
            mode=mode,
            approved_by=approved_by,
            scope=scope,
            notes=notes,
        )


@dataclass(frozen=True)
class WebObserver:
    """
    Configuration contract for one bounded institutional web observer.
    """

    name: str
    enabled: bool
    source_organization: str
    authority: SourceAuthority
    purposes: Tuple[str, ...]
    seed_urls: Tuple[str, ...]
    allowed_hosts: Tuple[str, ...]
    allowed_prefixes: Tuple[str, ...]
    storage_root: Path
    manifest_path: Path
    max_depth: int
    max_pages: int
    request_delay_seconds: float
    respect_robots: bool
    authorization: Optional[ObserverAuthorization] = None

    def __post_init__(self) -> None:
        if not self.name.strip():
            raise ValueError(
                "Observer name must not be empty."
            )

        if not self.seed_urls:
            raise ValueError(
                f"Observer {self.name!r} requires at least one seed URL."
            )

        if not self.allowed_hosts:
            raise ValueError(
                f"Observer {self.name!r} requires allowed hosts."
            )

        if not self.allowed_prefixes:
            raise ValueError(
                f"Observer {self.name!r} requires allowed prefixes."
            )

        if not self.respect_robots and self.authorization is None:
            raise ValueError(
                f"Observer {self.name!r} may disable robots enforcement "
                "only with explicit authorization metadata."
            )

        if self.authorization is not None:
            unauthorized_prefixes = [
                prefix
                for prefix in self.allowed_prefixes
                if not any(
                    prefix.startswith(scope)
                    or scope.startswith(prefix)
                    for scope in self.authorization.scope
                )
            ]

            if unauthorized_prefixes:
                raise ValueError(
                    f"Observer {self.name!r} contains allowed prefixes "
                    "outside its authorization scope: "
                    + ", ".join(unauthorized_prefixes)
                )

    @classmethod
    def from_dict(
        cls,
        payload: Dict[str, Any],
        project_root: Path,
    ) -> "WebObserver":
        observer_type = payload.get("type", "web")

        if observer_type != "web":
            raise ValueError(
                f"Unsupported observer type: {observer_type}"
            )

        storage_root = Path(payload["storage_root"])
        manifest_path = Path(payload["manifest"])

        if not storage_root.is_absolute():
            storage_root = project_root / storage_root

        if not manifest_path.is_absolute():
            manifest_path = project_root / manifest_path

        authorization_payload = payload.get("authorization")

        authorization = (
            ObserverAuthorization.from_dict(
                authorization_payload
            )
            if authorization_payload
            else None
        )

        return cls(
            name=payload["name"],
            enabled=bool(payload.get("enabled", True)),
            source_organization=payload[
                "source_organization"
            ],
            authority=SourceAuthority(payload["authority"]),
            purposes=tuple(payload.get("purposes", [])),
            seed_urls=tuple(payload["seed_urls"]),
            allowed_hosts=tuple(payload["allowed_hosts"]),
            allowed_prefixes=tuple(
                payload["allowed_prefixes"]
            ),
            storage_root=storage_root,
            manifest_path=manifest_path,
            max_depth=int(payload.get("max_depth", 2)),
            max_pages=int(payload.get("max_pages", 25)),
            request_delay_seconds=float(
                payload.get(
                    "request_delay_seconds",
                    0.5,
                )
            ),
            respect_robots=bool(
                payload.get("respect_robots", True)
            ),
            authorization=authorization,
        )


class WebObserverCatalog:
    """
    Read-only catalog of configured institutional web observers.
    """

    def __init__(
        self,
        observers: List[WebObserver],
    ) -> None:
        self._observers = list(observers)
        self._by_name = {}

        for observer in self._observers:
            if observer.name in self._by_name:
                raise ValueError(
                    f"Duplicate observer name: {observer.name}"
                )

            self._by_name[observer.name] = observer

