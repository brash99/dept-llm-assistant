#!/usr/bin/env python3

from __future__ import annotations

import argparse
from collections import Counter
from datetime import datetime, timezone
import json
from pathlib import Path
import ssl
import time
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

import certifi
import yaml

from app.acquisition.authority import SourceAuthority
from app.acquisition.filesystem import FilesystemAcquisitionService
from app.acquisition.manifest import AcquisitionManifest
from app.acquisition.method import AcquisitionMethod


USER_AGENT = (
    "InstitutionalSemanticObservatory/1.0 "
    "(governed public-resource acquisition)"
)


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def resolve_path(project_root: Path, value: str) -> Path:
    path = Path(value)

    if not path.is_absolute():
        path = project_root / path

    return path.resolve()


def download_resource(
    *,
    url: str,
    destination: Path,
    timeout_seconds: int,
) -> dict:
    request = Request(
        url,
        headers={
            "User-Agent": USER_AGENT,
            "Accept": "application/pdf, */*;q=0.5",
        },
    )

    context = ssl.create_default_context(
        cafile=certifi.where()
    )

    temporary = destination.with_suffix(
        destination.suffix + ".part"
    )

    temporary.unlink(missing_ok=True)

    try:
        with urlopen(
            request,
            timeout=timeout_seconds,
            context=context,
        ) as response:
            payload = response.read()
            content_type = (
                response.headers.get(
                    "Content-Type",
                    "",
                )
                .split(";", 1)[0]
                .casefold()
            )
            last_modified = response.headers.get(
                "Last-Modified"
            )

    except (HTTPError, URLError, TimeoutError) as error:
        return {
            "status": "failed",
            "error_type": type(error).__name__,
            "error": str(error),
        }

    if not (
        content_type == "application/pdf"
        or payload.startswith(b"%PDF-")
    ):
        return {
            "status": "rejected_non_pdf",
            "content_type": content_type,
            "size_bytes": len(payload),
        }

    temporary.write_bytes(payload)
    temporary.replace(destination)

    return {
        "status": "downloaded",
        "content_type": content_type,
        "size_bytes": len(payload),
        "last_modified": last_modified,
    }


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "Acquire an explicit catalog of governed public resources."
        )
    )

    parser.add_argument(
        "--config",
        type=Path,
        default=Path("config/schev_resources.yaml"),
    )

    parser.add_argument(
        "--resource",
        action="append",
        default=None,
        help=(
            "Acquire only the named resource key. "
            "May be supplied more than once."
        ),
    )

    parser.add_argument(
        "--dry-run",
        action="store_true",
    )

    args = parser.parse_args()

    project_root = Path.cwd().resolve()

    config_path = args.config

    if not config_path.is_absolute():
        config_path = project_root / config_path

    payload = yaml.safe_load(
        config_path.read_text(encoding="utf-8")
    ) or {}

    catalog = payload["catalog"]
    resources = payload.get("resources", [])

    selected_keys = (
        set(args.resource)
        if args.resource
        else None
    )

    if selected_keys is not None:
        known_keys = {
            str(resource["key"])
            for resource in resources
        }

        unknown = selected_keys - known_keys

        if unknown:
            raise SystemExit(
                "Unknown resource keys: "
                + ", ".join(sorted(unknown))
            )

        resources = [
            resource
            for resource in resources
            if resource["key"] in selected_keys
        ]

    storage_root = resolve_path(
        project_root,
        catalog["storage_root"],
    )

    manifest_path = resolve_path(
        project_root,
        catalog["manifest"],
    )

    report_path = resolve_path(
        project_root,
        catalog["report"],
    )

    storage_root.mkdir(parents=True, exist_ok=True)
    manifest_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )
    report_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    authority = SourceAuthority(
        catalog["authority"]
    )

    print("=" * 76)
    print(catalog["name"])
    print("=" * 76)
    print(f"Resources    : {len(resources)}")
    print(f"Storage root : {storage_root}")
    print(f"Manifest     : {manifest_path}")
    print()

    for resource in resources:
        print(
            f"{resource['key']:40} "
            f"{resource['url']}"
        )

    if args.dry_run:
        print()
        print("Dry run complete.")
        return

    filesystem = FilesystemAcquisitionService(
        storage_root
    )

    manifest = AcquisitionManifest(
        manifest_path
    )

    timeout = int(
        catalog.get(
            "download_timeout_seconds",
            120,
        )
    )

    delay = float(
        catalog.get(
            "request_delay_seconds",
            0.5,
        )
    )

    records = []
    counts = Counter()

    for index, resource in enumerate(
        resources,
        start=1,
    ):
        destination = (
            storage_root / resource["filename"]
        )

        print()
        print(
            f"[{index}/{len(resources)}] "
            f"{resource['key']}"
        )

        result = download_resource(
            url=resource["url"],
            destination=destination,
            timeout_seconds=timeout,
        )

        if result["status"] != "downloaded":
            counts[result["status"]] += 1

            record = {
                **resource,
                **result,
                "observed_at": now_iso(),
            }

            records.append(record)

            print(
                f"  [FAIL] {result['status']}: "
                f"{result.get('error', '')}"
            )
            continue

        source_document = filesystem.acquire(
            source_file=destination,
            title=resource["title"],
            source_organization=(
                catalog["source_organization"]
            ),
            authority=authority,
            acquisition_method=(
                AcquisitionMethod.DIRECT_DOWNLOAD
            ),
            source_url=resource["url"],
            publication_date=resource.get(
                "publication_date"
            ),
            media_type=result.get(
                "content_type"
            ),
        )

        decision = manifest.record(
            source_document
        )

        status = decision.status.value
        counts[status] += 1

        record = {
            **resource,
            **result,
            "status": status,
            "relative_path": (
                source_document.relative_path
            ),
            "content_hash": (
                source_document.content_hash
            ),
            "authority": authority.value,
            "acquisition_method": (
                AcquisitionMethod
                .DIRECT_DOWNLOAD
                .value
            ),
            "observed_at": now_iso(),
        }

        records.append(record)

        print(
            f"  [{status.upper()}] "
            f"{source_document.relative_path}"
        )

        if index < len(resources):
            time.sleep(delay)

    report = {
        "catalog_key": catalog["key"],
        "catalog_name": catalog["name"],
        "completed_at": now_iso(),
        "resource_count": len(resources),
        "status_counts": dict(counts),
        "resources": records,
    }

    report_path.write_text(
        json.dumps(
            report,
            indent=2,
            sort_keys=True,
            default=str,
        )
        + "\n",
        encoding="utf-8",
    )

    print()
    print("=" * 76)
    print("Results")
    print("=" * 76)

    for status, count in sorted(
        counts.items()
    ):
        print(f"{status:24} {count:6d}")

    print()
    print(f"Report:   {report_path}")
    print(f"Manifest: {manifest_path}")


if __name__ == "__main__":
    main()
